---
// 第1章专用 ChapterCloser，数据内嵌
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  '你每次点按钮、刷页面，背后都是一次"请求-响应"：浏览器问，服务器答。',
  '服务器不是黑盒子，就是个替你跑腿的中转站——收请求、查数据库、回答你。',
  '"前端""后端""数据库"不是三个平行的神秘概念，是同一趟快递上的三个工位。',
  '产品从你脑子里到用户手机里，中间每一步都有名字、都能拆开看。这一章你已经全见过了。',
];

const quote = {
  text: '听起来像魔法的东西，拆开以后通常只是几个工位在按顺序干活。',
  attribution: '任何一个真正理解过这件事的人，都会点头',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
