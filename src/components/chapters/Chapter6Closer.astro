---
// 第6章专用 ChapterCloser，数据内嵌
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  '域名是给人记的招牌，IP 是给机器用的地址，DNS 是把招牌翻译成地址的电话簿。',
  'HTTPS 那把小锁头不是装饰——它让路上任何中间人都看不到你的密码和数据。',
  '买域名一年几十到几百块，配 DNS 就几分钟，ICP 备案（大陆）需要等 1-2 周。',
  '拥有自己的域名，才算真正"在互联网上有个家"。',
];

const quote = {
  text: '拥有一个属于自己的域名，是互联网时代的公民身份证。',
  attribution: '从 IP 到域名这一步，感觉自己终于有了个真实的地址',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
