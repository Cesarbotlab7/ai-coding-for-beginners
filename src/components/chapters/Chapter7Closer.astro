---
// 第7章专用 ChapterCloser，数据内嵌
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  'Claude Code 是助理，不是神。它需要你描述清楚——目标、约束、不确定的部分。',
  'Plan 模式适合"动之前先对齐"，直接描述适合"改个已知的小地方"。',
  '永远不要把 API key 粘进对话。让 AI 从环境变量读密钥，不是直接告诉它。',
  '会提问的小白 > 只会复制粘贴的程序员——不是鸡汤，是 2025 年的现实。',
];

const quote = {
  text: 'AI 时代最有价值的技能，不是写代码，是把事情说清楚。',
  attribution: '你学这个教程的原因，可能比你以为的更重要',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
