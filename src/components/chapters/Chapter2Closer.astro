---
// 第2章专用 ChapterCloser，数据内嵌
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  '前端是客人看得见的部分（门面、菜单、服务员），后端是看不见但真正在干活的部分（后厨）。',
  '前端三件套：HTML 是骨架，CSS 是衣服，JavaScript 是让它动起来的肌肉。名字先记住，怎么写后面再说。',
  '数据库和服务器是两件不同的事——一个管存什么，一个管在哪。',
  '这五个词——前端、后端、数据库、服务器、域名——你已经都会用了。下次不会再假笑了。',
];

const quote = {
  text: '世界上所有的互联网产品，本质上都是同一家餐厅的不同装修。',
  attribution: '你现在已经看懂了这家餐厅的结构图',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
