---
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  'vibe coding 的第一步不是追最强工具，而是配一套稳定、看得见、能持续使用的装备。',
  '编辑器像门店，Agent 像会进厨房的师傅，模型像发动机；先分清层级，再做选择。',
  'Claude Code 不是网页——它跑在你的终端里，直接操作你电脑上的文件。',
  '账号和 API Key 都是通行证，不要发给任何人，不要提交到 GitHub。',
  '语音输入能帮你把需求说完整；AI 最怕的不是你不会代码，而是你没讲清楚目标。',
];

const quote = {
  text: '工具不是越多越好。能稳定开工的那一套，才是第一套。',
  attribution: '现在选定路线，再打开终端',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
