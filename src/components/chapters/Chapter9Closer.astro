---
// 第9章专用 ChapterCloser，整套课程终点，数据内嵌
import ChapterCloser from '../ChapterCloser.astro';

const takeaways = [
  '上线不是胜利，是获得了一张"每天打怪"的入场券。这是开始，不是结束。',
  '不要追求一次做完美。追求"能改"——因为你永远不知道上线之前哪里会出问题。',
  'bug 定位的标准流程：读报错 → 找那一行代码 → 理解为什么 → 改 → 测 → 推上去。',
  '你已经会造东西、会修东西、会改东西了。剩下的，是在真实项目里积累的时间。',
];

const quote = {
  text: '这个教程到这里结束了。你的项目才刚开始。欢迎加入这个每天都在修修补补、但每天都在变好的世界。',
  attribution: '每一个还在维护自己项目的人，都在用行动证明这件事值得',
};
---
<ChapterCloser takeaways={takeaways} quote={quote} />
