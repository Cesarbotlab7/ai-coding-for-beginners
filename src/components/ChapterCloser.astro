---
interface Props {
  slug: string;
  takeaways: string[];
  next?: {
    slug: string;
    order: number;
    title: string;
  };
}

const { slug, takeaways, next } = Astro.props;
---
<section class="closer" data-lesson-closer data-slug={slug}>
  <div class="takeaways">
    <h2>这一单元，你已经会了</h2>
    <ul>
      {takeaways.map((takeaway) => <li>{takeaway}</li>)}
    </ul>
  </div>

  <div class="completion">
    <div>
      <p class="completion-label">学习进度只保存在这台设备的浏览器里</p>
      <p class="completion-status" aria-live="polite">完成互动后，可以标记这一单元。</p>
    </div>
    <button type="button" class="primary" data-complete-button>标记本单元已完成</button>
  </div>

  {next && (
    <a class="next-card" href={`/chapter/${next.slug}`}>
      <span>下一单元 · {next.order}</span>
      <strong>{next.title}</strong>
    </a>
  )}
</section>

<script>
  const STORAGE_KEY = 'workbuddy-course-progress-v1';

  document.querySelectorAll<HTMLElement>('[data-lesson-closer]').forEach((root) => {
    const slug = root.dataset.slug;
    const button = root.querySelector<HTMLButtonElement>('[data-complete-button]');
    const status = root.querySelector<HTMLElement>('.completion-status');
    if (!slug || !button || !status) return;

    const readProgress = (): string[] => {
      try {
        const value = JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]');
        return Array.isArray(value) ? value.filter((item) => typeof item === 'string') : [];
      } catch {
        return [];
      }
    };

    const render = () => {
      const completed = readProgress().includes(slug);
      button.textContent = completed ? '已完成，点击可撤销' : '标记本单元已完成';
      button.classList.toggle('primary', !completed);
      status.textContent = completed
        ? '这一单元已记录为完成。'
        : '完成互动后，可以标记这一单元。';
    };

    button.addEventListener('click', () => {
      const progress = new Set(readProgress());
      if (progress.has(slug)) progress.delete(slug);
      else progress.add(slug);
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...progress]));
      render();
    });

    render();
  });
</script>

<style>
  .closer {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .takeaways {
    padding: var(--space-5);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
  }

  .takeaways h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--text-md);
  }

  .takeaways ul {
    margin: 0;
  }

  .completion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-bg-secondary);
  }

  .completion p {
    margin: 0;
  }

  .completion-label,
  .completion-status {
    font-size: var(--text-sm);
  }

  .completion-status {
    color: var(--color-text-secondary);
  }

  .next-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--color-bg-info);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .next-card span {
    color: var(--color-text-info);
    font-size: var(--text-xs);
  }

  .next-card strong {
    font-size: var(--text-md);
    font-weight: var(--font-medium);
  }

  @media (max-width: 40rem) {
    .completion {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
