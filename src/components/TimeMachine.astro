---
// GitHub 时间机模拟器：演示 commit 历史和回滚
---

<div class="tm-root">
  <div class="tm-layout">
    <div class="tm-editor-col">
      <div class="tm-editor-header">
        <span class="tm-editor-title">代码编辑器</span>
        <span class="tm-badge" id="tmBadge">当前版本</span>
      </div>
      <pre class="tm-code" id="tmCode" aria-live="polite" aria-label="当前代码内容"></pre>
    </div>

    <div class="tm-history-col">
      <div class="tm-history-header">提交历史</div>
      <ol class="tm-commits" id="tmCommits" reversed aria-label="commit 历史列表"></ol>
    </div>
  </div>

  <div class="tm-controls">
    <button class="tm-btn tm-btn--primary" id="tmNextBtn" type="button">下一步 →</button>
    <button class="tm-btn tm-btn--ghost" id="tmResetBtn" type="button">重新开始</button>
  </div>

  <p class="tm-hint" id="tmHint" aria-live="polite"></p>
</div>

<style>
  .tm-root {
    margin: var(--space-6) 0;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-primary);
  }

  .tm-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 280px;
  }

  .tm-editor-col {
    border-right: 0.5px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  .tm-editor-header,
  .tm-history-header {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-secondary);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .tm-badge {
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 99px;
    background: var(--color-bg-success);
    color: var(--color-text-success);
  }

  .tm-badge.broken {
    background: var(--color-bg-danger);
    color: var(--color-text-danger);
  }

  .tm-code {
    flex: 1;
    margin: 0;
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.7;
    color: var(--color-text-primary);
    background: none;
    white-space: pre-wrap;
    word-break: break-word;
    transition: color 0.3s;
  }

  .tm-code.broken {
    color: var(--color-text-danger);
  }

  .tm-history-col {
    display: flex;
    flex-direction: column;
  }

  .tm-commits {
    flex: 1;
    margin: 0;
    padding: var(--space-3);
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    overflow-y: auto;
  }

  .tm-commit {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    transition: border-color 0.2s;
  }

  .tm-commit.tm-active {
    border-color: var(--color-text-success);
    background: var(--color-bg-success);
  }

  .tm-commit.tm-broken {
    border-color: var(--color-text-danger);
    background: var(--color-bg-danger);
  }

  .tm-commit-msg {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
    line-height: 1.4;
  }

  .tm-commit.tm-active .tm-commit-msg { color: var(--color-text-success); }
  .tm-commit.tm-broken .tm-commit-msg { color: var(--color-text-danger); }

  .tm-commit-meta {
    font-size: 10px;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .tm-rollback-btn {
    display: block;
    width: 100%;
    margin-top: var(--space-2);
    padding: var(--space-1) var(--space-2);
    font-size: 10px;
    border: 1px solid var(--color-text-info);
    border-radius: var(--radius-sm);
    background: var(--color-bg-info);
    color: var(--color-text-info);
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .tm-rollback-btn:hover { opacity: 0.8; }

  .tm-controls {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-top: 0.5px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .tm-btn {
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .tm-btn--primary {
    background: var(--color-text-info);
    color: #fff;
    border: none;
  }

  .tm-btn--ghost {
    background: none;
    border: 1px solid var(--color-border-secondary);
    color: var(--color-text-secondary);
  }

  .tm-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .tm-btn:not(:disabled):hover { opacity: 0.85; }

  .tm-hint {
    padding: var(--space-2) var(--space-4) var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-align: center;
    min-height: 2rem;
  }

  @media (max-width: 560px) {
    .tm-layout { grid-template-columns: 1fr; }
    .tm-editor-col { border-right: none; border-bottom: 0.5px solid var(--color-border); }
    .tm-history-col { min-height: 200px; }
  }
</style>

<script>
  (function () {
    var steps = [
      {
        code: '# v1 基础版本\ndef get_news():\n    return db.query(\n        "SELECT * FROM news_items"\n    )',
        msg:  'feat: 完成资讯查询基础功能',
        hash: 'a1b2c3',
        time: '昨天 14:22',
        broken: false,
        hint: '初始版本。能查出数据，但没有排序，顺序是随机的。'
      },
      {
        code: '# v2 加排序\ndef get_news():\n    return db.query(\n        "SELECT * FROM news_items"\n        " ORDER BY importance_score DESC"\n    )',
        msg:  'fix: 按重要性分数降序排列',
        hash: 'd4e5f6',
        time: '昨天 16:08',
        broken: false,
        hint: '修复了排序问题。现在最重要的资讯排在最前面。'
      },
      {
        code: '# v3 加信源筛选\ndef get_news(source=None):\n    q = "SELECT * FROM news_items WHERE is_representative=true"\n    if source:\n        q += f" AND source_type=\'{source}\'"\n    return db.query(q + " ORDER BY importance_score DESC")',
        msg:  'feat: 加信源 Tab 筛选（twitter/rss/hn/arxiv）',
        hash: 'g7h8i9',
        time: '今天 09:41',
        broken: false,
        hint: '好功能！现在用户可以按来源过滤资讯了。'
      },
      {
        code: '# 出问题了！\ndef get_news(source=None):\n    q = "SELECT * FROM news_items WHERE is_representative=true"\n    if source:\n        q += f" AND source_type={source}"  # 忘记加引号！\n    return db.query(q + " ORDER BY importance_score DESC")\n    # 报错：column "twitter" does not exist',
        msg:  'feat: 尝试加搜索功能（已破坏）',
        hash: 'j1k2l3',
        time: '今天 11:15',
        broken: true,
        hint: '出问题了——string 变量拼进了 SQL 但忘记加引号，所有筛选都报错。这时候你需要回滚！'
      }
    ];

    var currentStep = 0;
    var unlockedStep = 0;

    var codeEl   = document.getElementById('tmCode');
    var badgeEl  = document.getElementById('tmBadge');
    var commitsEl = document.getElementById('tmCommits');
    var nextBtn  = document.getElementById('tmNextBtn');
    var resetBtn = document.getElementById('tmResetBtn');
    var hintEl   = document.getElementById('tmHint');

    if (!codeEl || !badgeEl || !commitsEl || !nextBtn || !resetBtn || !hintEl) return;

    function renderCommits() {
      commitsEl.innerHTML = '';
      for (var i = 0; i <= unlockedStep; i++) {
        var s = steps[i];
        var li = document.createElement('li');
        li.className = 'tm-commit' +
          (i === currentStep ? (s.broken ? ' tm-broken' : ' tm-active') : '');

        var msgEl = document.createElement('div');
        msgEl.className = 'tm-commit-msg';
        msgEl.textContent = s.msg;

        var metaEl = document.createElement('div');
        metaEl.className = 'tm-commit-meta';
        metaEl.textContent = s.hash + '  ·  ' + s.time;

        li.appendChild(msgEl);
        li.appendChild(metaEl);

        if (i < currentStep && i !== unlockedStep) {
          (function (idx) {
            var btn = document.createElement('button');
            btn.className = 'tm-rollback-btn';
            btn.type = 'button';
            btn.textContent = '回到这个版本';
            btn.addEventListener('click', function () {
              currentStep = idx;
              renderAll();
            });
            li.appendChild(btn);
          })(i);
        }

        if (s.broken && i === currentStep) {
          (function (idx) {
            var prevIdx = idx - 1;
            if (prevIdx >= 0) {
              var btn = document.createElement('button');
              btn.className = 'tm-rollback-btn';
              btn.type = 'button';
              btn.textContent = '← 回到上一个正常版本';
              btn.addEventListener('click', function () {
                currentStep = prevIdx;
                renderAll();
              });
              li.appendChild(btn);
            }
          })(i);
        }

        commitsEl.appendChild(li);
      }
    }

    function renderAll() {
      var s = steps[currentStep];
      codeEl.textContent = s.code;
      codeEl.className   = 'tm-code' + (s.broken ? ' broken' : '');
      badgeEl.textContent = s.broken ? '有问题！' : '当前版本';
      badgeEl.className   = 'tm-badge' + (s.broken ? ' broken' : '');
      hintEl.textContent  = s.hint;
      nextBtn.disabled    = unlockedStep >= steps.length - 1 && currentStep === unlockedStep;
      renderCommits();
    }

    nextBtn.addEventListener('click', function () {
      if (unlockedStep < steps.length - 1) {
        unlockedStep++;
        currentStep = unlockedStep;
        renderAll();
        if (unlockedStep >= steps.length - 1) {
          nextBtn.textContent = '已到最后一步';
          nextBtn.disabled = true;
        }
      }
    });

    resetBtn.addEventListener('click', function () {
      currentStep  = 0;
      unlockedStep = 0;
      nextBtn.textContent = '下一步 →';
      renderAll();
    });

    renderAll();
  })();
</script>
