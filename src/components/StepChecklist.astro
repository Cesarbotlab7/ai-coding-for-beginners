---
// 动手教程交互清单，步骤解锁式
const steps = [
  {
    id: 's1',
    title: '安装 Node.js',
    desc: '去 nodejs.org，下载 LTS（长期稳定版），双击安装。安装完后打开终端，输入 node -v，看到版本号说明成功。',
    check: '你的终端能输出 node -v 的版本号（如 v20.11.0）',
  },
  {
    id: 's2',
    title: '安装 VS Code',
    desc: '去 code.visualstudio.com，下载 Mac 版，拖进 Applications 文件夹。这是你以后最常用的代码编辑器。',
    check: 'VS Code 打开了，能看到欢迎页面',
  },
  {
    id: 's3',
    title: '安装 Claude Code',
    desc: '按官网当前安装命令安装 Claude Code。\n启动后用 Claude.ai 账号授权，或者输入你的 Anthropic API Key。套餐、额度和价格以官网为准。',
    check: '终端输入 claude，能进入对话界面',
  },
  {
    id: 's4',
    title: '创建项目文件夹',
    desc: '在终端运行：\nmkdir my-ai-news\ncd my-ai-news\n\n然后在 VS Code 里打开这个文件夹（File → Open Folder）。',
    check: 'VS Code 左侧显示 my-ai-news 文件夹（目前是空的）',
  },
  {
    id: 's5',
    title: '用 Claude Code 初始化项目',
    desc: '在 VS Code 的终端里，输入 claude，然后说：\n"帮我用 Astro 创建一个最简单的项目，有首页，用 CSS 变量设计系统，不要安装任何额外框架"',
    check: '项目里出现了 src/ 文件夹、astro.config.mjs、package.json',
  },
  {
    id: 's6',
    title: '加入假数据和资讯卡片',
    desc: '继续告诉 Claude Code：\n"创建一个 src/data/news.json，里面放 4 条假的 AI 资讯。然后在首页读取这个文件，用卡片列表展示：标题、来源、时间"',
    check: '首页代码里能看到卡片组件，数据来自 news.json',
  },
  {
    id: 's7',
    title: '运行起来，在浏览器里看到它',
    desc: '在终端运行：\nnpm install\nnpm run dev\n\n打开浏览器，访问 http://localhost:4321',
    check: '浏览器里出现了你的资讯卡片页面——哪怕很丑，它活着就行',
  },
];
---

<div class="sc-root" id="scRoot">
  <div class="sc-steps" id="scSteps">
    {steps.map((step, idx) => (
      <div
        class={`sc-step ${idx === 0 ? 'sc-unlocked' : 'sc-locked'}`}
        id={`scStep-${idx}`}
        data-idx={idx}
      >
        <div class="sc-step-header">
          <button
            class="sc-checkbox"
            id={`scCheck-${idx}`}
            type="button"
            disabled={idx !== 0}
            aria-label={`标记第${idx + 1}步完成：${step.title}`}
            aria-pressed="false"
          >
            <span class="sc-check-inner" aria-hidden="true"></span>
          </button>
          <span class="sc-step-num">{idx + 1}</span>
          <span class="sc-step-title">{step.title}</span>
          {idx !== 0 && <span class="sc-lock-badge" aria-hidden="true">🔒</span>}
        </div>
        <div class="sc-step-body">
          <p class="sc-step-desc">{step.desc}</p>
          <div class="sc-step-check">
            <span class="sc-check-label" aria-hidden="true">✓</span>
            <span class="sc-check-text">{step.check}</span>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="sc-done" id="scDone" hidden aria-live="polite">
    <div class="sc-done-icon" aria-hidden="true">🎉</div>
    <p class="sc-done-title">你做到了！</p>
    <p class="sc-done-body">
      你现在有一个跑在自己电脑上的 AI 资讯页面。它可能很丑、数据是假的——但它是真实运行的项目，不是教程里的截图。<br/><br/>
      这就是 AI 资讯平台出生时的样子。接下来，你可以慢慢把假数据换成真爬虫、把写死的摘要换成真 AI API。<br/><br/>
      <strong>先让它活着，再让它聪明。</strong>
    </p>
    <button class="sc-restart" id="scRestart" type="button">从头来过</button>
  </div>
</div>

<style>
  .sc-root {
    margin: var(--space-6) 0;
  }

  .sc-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .sc-step {
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .sc-step.sc-unlocked { border-color: var(--color-border-secondary); }
  .sc-step.sc-completed { border-color: var(--color-text-success); }
  .sc-step.sc-locked { opacity: 0.5; }

  .sc-step-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    cursor: default;
  }

  .sc-step.sc-completed .sc-step-header {
    background: var(--color-bg-success);
  }

  .sc-checkbox {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border-secondary);
    background: var(--color-bg-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .sc-checkbox:not(:disabled):hover {
    border-color: var(--color-text-success);
  }

  .sc-checkbox:disabled { cursor: not-allowed; }

  .sc-step.sc-completed .sc-checkbox {
    background: var(--color-text-success);
    border-color: var(--color-text-success);
  }

  .sc-check-inner {
    display: none;
    width: 10px;
    height: 6px;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
  }

  .sc-step.sc-completed .sc-check-inner { display: block; }

  .sc-step-num {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-tertiary);
    width: 20px;
    text-align: center;
  }

  .sc-step-title {
    flex: 1;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
  }

  .sc-step.sc-completed .sc-step-title {
    color: var(--color-text-success);
    text-decoration: line-through;
    text-decoration-color: var(--color-text-success);
  }

  .sc-lock-badge {
    font-size: var(--text-xs);
  }

  .sc-step.sc-unlocked .sc-lock-badge,
  .sc-step.sc-completed .sc-lock-badge {
    display: none;
  }

  .sc-step-body {
    padding: var(--space-3) var(--space-4);
    display: none;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sc-step.sc-unlocked .sc-step-body,
  .sc-step.sc-completed .sc-step-body {
    display: flex;
  }

  .sc-step-desc {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    white-space: pre-line;
    font-family: inherit;
  }

  .sc-step-check {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
  }

  .sc-check-label {
    color: var(--color-text-success);
    font-weight: var(--font-medium);
    flex-shrink: 0;
  }

  .sc-check-text {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .sc-done {
    padding: var(--space-5);
    background: var(--color-bg-success);
    border-radius: var(--radius-lg);
    text-align: center;
    animation: scFadeUp 0.4s ease both;
  }

  @keyframes scFadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .sc-done-icon { font-size: 2.5rem; margin-bottom: var(--space-2); }

  .sc-done-title {
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--color-text-success);
    margin: 0 0 var(--space-3);
  }

  .sc-done-body {
    font-size: var(--text-sm);
    color: var(--color-text-success);
    line-height: 1.75;
    margin: 0 0 var(--space-4);
  }

  .sc-restart {
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--color-text-success);
    border-radius: var(--radius-md);
    background: var(--color-bg-primary);
    font-size: var(--text-sm);
    color: var(--color-text-success);
    cursor: pointer;
  }
</style>

<script>
  (function () {
    var total    = 7;
    var doneEl   = document.getElementById('scDone');
    var restartBtn = document.getElementById('scRestart');

    if (!doneEl || !restartBtn) return;

    function getStep(idx) {
      return document.getElementById('scStep-' + idx);
    }
    function getCheckBtn(idx) {
      return document.getElementById('scCheck-' + idx);
    }

    function unlockStep(idx) {
      var el = getStep(idx);
      var btn = getCheckBtn(idx);
      if (!el || !btn) return;
      el.className = 'sc-step sc-unlocked';
      btn.disabled = false;
      el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function completeStep(idx) {
      var el  = getStep(idx);
      var btn = getCheckBtn(idx);
      if (!el || !btn) return;
      el.className = 'sc-step sc-completed';
      btn.setAttribute('aria-pressed', 'true');

      if (idx + 1 < total) {
        unlockStep(idx + 1);
      } else {
        doneEl.hidden = false;
        doneEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    for (var i = 0; i < total; i++) {
      (function (idx) {
        var btn = getCheckBtn(idx);
        if (!btn) return;
        btn.addEventListener('click', function () {
          var el = getStep(idx);
          if (el && el.classList.contains('sc-completed')) return;
          completeStep(idx);
        });
      })(i);
    }

    restartBtn.addEventListener('click', function () {
      doneEl.hidden = true;
      for (var i = 0; i < total; i++) {
        var el  = getStep(i);
        var btn = getCheckBtn(i);
        if (el) el.className = i === 0 ? 'sc-step sc-unlocked' : 'sc-step sc-locked';
        if (btn) {
          btn.disabled = i !== 0;
          btn.setAttribute('aria-pressed', 'false');
        }
      }
    });
  })();
</script>
