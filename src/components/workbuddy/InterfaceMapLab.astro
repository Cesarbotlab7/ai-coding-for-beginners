---
import WorkBuddyShell from './WorkBuddyShell.astro';
---
<section class="wb-lab" data-interface-map>
  <header class="wb-lab__header">
    <span class="wb-lab__eyebrow">互动 05</span>
    <h2 class="wb-lab__title">在当前 WorkBuddy 界面上点一遍</h2>
    <p class="wb-lab__description">布局和控件按 WorkBuddy v5.2.6 客户端重建；示例任务和账号为虚构数据。</p>
  </header>

  <WorkBuddyShell interactiveMap={true} artifactEmpty={true} />

  <div class="wb-status map-status" aria-live="polite" data-map-explanation>
    先点击左侧导航、输入框下方控件或右侧“产物”，查看它负责什么。
  </div>
</section>

<script>
  const explanations = {
    tasks: '新建任务：从这里开始一个独立任务。左栏下方会保留任务历史。',
    assistant: '助理：用于从手机或外部入口触发电脑上的 WorkBuddy。',
    project: '项目：把同一目标下的资料、任务和上下文组织在一起。',
    experts: '专家·技能·连接器：分别提供领域判断、稳定方法和外部应用连接。',
    automation: '自动化：把已经手动验收过的流程设成定时或触发执行。',
    more: '更多：资料库和灵感等扩展入口放在这里。',
    'more-actions': '更多操作：添加文件，以及选择默认模式、Plan 或 Ask；专家、技能和连接器也从这里调用。',
    model: 'Auto：这是模型选择。它和工作模式、权限不是同一个开关。',
    workspace: '选择工作空间：决定本次任务主要读取和保存文件的范围。',
    permission: '默认权限：超出安全沙箱时会停下来请求你的允许。',
    artifact: '产物：WorkBuddy 交付的文件会出现在右栏。打开文件后再开始验收。',
  };

  document.querySelectorAll<HTMLElement>('[data-interface-map]').forEach((root) => {
    const buttons = [...root.querySelectorAll<HTMLButtonElement>('[data-point]')];
    const explanation = root.querySelector<HTMLElement>('[data-map-explanation]');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        buttons.forEach((item) => item.removeAttribute('data-highlighted'));
        button.setAttribute('data-highlighted', 'true');
        const key = button.dataset.point as keyof typeof explanations;
        if (explanation && key in explanations) explanation.textContent = explanations[key];
      });
    });
  });
</script>

<style>
  .map-status {
    min-height: var(--control-height);
  }

  [data-interface-map] :global([data-point][data-highlighted="true"]) {
    outline: var(--focus-ring-width) solid var(--color-text-info);
    outline-offset: var(--space-1);
  }
</style>
