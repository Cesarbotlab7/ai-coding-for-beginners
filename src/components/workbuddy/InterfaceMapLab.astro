<section class="wb-lab" data-interface-map>
  <header class="wb-lab__header">
    <span class="wb-lab__eyebrow">互动 05</span>
    <h2 class="wb-lab__title">点一遍 WorkBuddy 的任务页</h2>
    <p class="wb-lab__description">这是教学用简化界面，不逐像素复制真实客户端。</p>
  </header>

  <div class="workbench">
    <section class="workbench-panel side">
      <h3>左边：你要去哪</h3>
      <button type="button" data-point="tasks">新建任务</button>
      <button type="button" data-point="assistant">助理</button>
      <button type="button" data-point="experts">专家与技能</button>
    </section>

    <section class="workbench-panel conversation">
      <h3>中间：任务怎么推进</h3>
      <div class="wb-card wb-mono">把 meeting-notes.txt 整理成正式纪要。</div>
      <div class="wb-actions">
        <button type="button" data-point="mode">Plan</button>
        <button type="button" data-point="workspace">练习工作区</button>
        <button type="button" data-point="permission">默认权限</button>
      </div>
    </section>

    <section class="workbench-panel result">
      <h3>右边：交付了什么</h3>
      <button type="button" data-point="artifact">产物</button>
      <div class="wb-card wb-mono">meeting-summary.md</div>
    </section>
  </div>

  <div class="wb-status" aria-live="polite" data-map-explanation>
    先点击任意一个控件，查看它负责什么。
  </div>
</section>

<script>
  const explanations = {
    tasks: '新建任务：每个任务有独立对话和工作区。真正处理文件从这里开始。',
    assistant: '助理：从手机或即时通讯工具远程触发电脑上的 WorkBuddy。',
    experts: '专家与技能：一个提供领域判断，一个提供稳定操作方法。',
    mode: '工作模式：Ask 只了解，Plan 先审计划，Craft 直接执行。',
    workspace: '工作区：本次任务主要读取和保存文件的范围。',
    permission: '权限：默认权限会在敏感动作前停下来让你确认。',
    artifact: '产物：WorkBuddy 交付的目标文件。打开它，才能开始验收。',
  };

  document.querySelectorAll<HTMLElement>('[data-interface-map]').forEach((root) => {
    const buttons = [...root.querySelectorAll<HTMLButtonElement>('[data-point]')];
    const explanation = root.querySelector<HTMLElement>('[data-map-explanation]');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        buttons.forEach((item) => item.removeAttribute('aria-current'));
        button.setAttribute('aria-current', 'true');
        const key = button.dataset.point as keyof typeof explanations;
        if (explanation) explanation.textContent = explanations[key];
      });
    });
  });
</script>

<style>
  .workbench {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.6fr) minmax(0, 1fr);
    gap: var(--space-3);
  }

  .workbench-panel {
    display: grid;
    align-content: start;
    gap: var(--space-3);
    min-height: var(--panel-min-height);
    padding: var(--space-4);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
  }

  .workbench-panel h3 {
    font-size: var(--text-sm);
  }

  .workbench-panel button[aria-current="true"] {
    border-color: var(--color-text-info);
    background: var(--color-bg-info);
    color: var(--color-text-info);
  }

  @media (max-width: 40rem) {
    .workbench {
      grid-template-columns: 1fr;
    }
  }
</style>
