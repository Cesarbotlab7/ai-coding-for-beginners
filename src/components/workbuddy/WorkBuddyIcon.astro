---
interface Props {
  name:
    | 'plus'
    | 'assistant'
    | 'project'
    | 'tools'
    | 'automation'
    | 'more'
    | 'search'
    | 'filter'
    | 'file'
    | 'folder'
    | 'shield'
    | 'model'
    | 'microphone'
    | 'send'
    | 'gift'
    | 'panel'
    | 'paperclip'
    | 'sparkles'
    | 'chevron';
}

const { name } = Astro.props;
---
<svg
  class="wb-client-icon"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'plus' && <><path d="M12 5v14" /><path d="M5 12h14" /></>}
  {name === 'assistant' && <><circle cx="12" cy="8" r="4" /><path d="M5 21a7 7 0 0 1 14 0" /><path d="M18 4l1 1" /></>}
  {name === 'project' && <><path d="M3 7h7l2 2h9v10H3z" /><path d="M3 7V5h7l2 2" /></>}
  {name === 'tools' && <><circle cx="7" cy="7" r="3" /><circle cx="17" cy="17" r="3" /><path d="m9 9 6 6" /><path d="m15 5 4 4" /></>}
  {name === 'automation' && <><path d="M4 12a8 8 0 0 1 14-5" /><path d="m18 3 .5 4-4 .5" /><path d="M20 12a8 8 0 0 1-14 5" /><path d="m6 21-.5-4 4-.5" /></>}
  {name === 'more' && <><circle cx="5" cy="12" r="1" /><circle cx="12" cy="12" r="1" /><circle cx="19" cy="12" r="1" /></>}
  {name === 'search' && <><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></>}
  {name === 'filter' && <path d="M4 5h16l-6 7v6l-4 2v-8z" />}
  {name === 'file' && <><path d="M6 3h8l4 4v14H6z" /><path d="M14 3v5h5" /></>}
  {name === 'folder' && <path d="M3 6h7l2 2h9v11H3z" />}
  {name === 'shield' && <><path d="M12 3 20 6v5c0 5-3 8-8 10-5-2-8-5-8-10V6z" /><path d="m9 12 2 2 4-4" /></>}
  {name === 'model' && <><circle cx="12" cy="12" r="3" /><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2" /></>}
  {name === 'microphone' && <><rect x="9" y="3" width="6" height="11" rx="3" /><path d="M5 11a7 7 0 0 0 14 0M12 18v3" /></>}
  {name === 'send' && <><path d="m5 12 7-7 7 7" /><path d="M12 5v14" /></>}
  {name === 'gift' && <><path d="M4 9h16v12H4z" /><path d="M2 5h20v4H2zM12 5v16" /><path d="M12 5H8a2 2 0 1 1 2-2c0 2 2 2 2 2ZM12 5h4a2 2 0 1 0-2-2c0 2-2 2-2 2Z" /></>}
  {name === 'panel' && <><rect x="3" y="4" width="18" height="16" rx="2" /><path d="M15 4v16" /></>}
  {name === 'paperclip' && <path d="m21 11-8.5 8.5a6 6 0 0 1-8.5-8.5l9-9a4 4 0 0 1 5.5 5.5l-9 9a2 2 0 0 1-3-3L15 5" />}
  {name === 'sparkles' && <><path d="m12 3 1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5z" /><path d="m19 15 .7 2.3L22 18l-2.3.7L19 21l-.7-2.3L16 18l2.3-.7z" /></>}
  {name === 'chevron' && <path d="m9 7 5 5-5 5" />}
</svg>

<style>
  .wb-client-icon {
    inline-size: var(--wb-icon-size);
    block-size: var(--wb-icon-size);
    flex: 0 0 auto;
    stroke-width: var(--wb-icon-stroke);
  }
</style>
