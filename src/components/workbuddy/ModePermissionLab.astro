---
import WorkBuddyShell from './WorkBuddyShell.astro';
---
<section class="wb-lab" data-mode-permission-lab>
  <header class="wb-lab__header">
    <span class="wb-lab__eyebrow">互动 04</span>
    <h2 class="wb-lab__title">在真实位置里选择模式和权限</h2>
    <p class="wb-lab__description">当前客户端把 Ask / Plan 放在“更多操作 → 模式”，权限在输入框下方单独设置。</p>
  </header>

  <label class="wb-field">
    <span>先选择一个任务</span>
    <select data-scenario>
      <option value="question">解释这份报告讲了什么，不修改文件</option>
      <option value="multi">把五份表格合并、生成图表并保存</option>
      <option value="simple">把一份文档另存为 Markdown</option>
      <option value="risky">批量删除原始资料中的重复文件</option>
    </select>
  </label>

  <WorkBuddyShell openMenu="mode" artifactEmpty={true}>
    <div slot="composer" class="scenario-in-composer">
      <span class="scenario-label">准备输入</span>
      <p data-scenario-copy>解释这份报告讲了什么，不修改文件</p>
    </div>
  </WorkBuddyShell>

  <p class="wb-status success decision-status" aria-live="polite" data-recommendation>
    推荐：<strong data-work-mode>Ask</strong> + <strong data-permission-mode>默认权限</strong>。<span data-recommendation-reason>先了解信息，不需要修改文件。</span>
  </p>

  <details class="full-access-note">
    <summary>那什么时候用“允许完全访问”？</summary>
    <p>只有你理解风险、任务可恢复、文件已隔离，而且愿意减少确认步骤时，才短时间考虑。它不是“更聪明”，只是“少拦几次”。</p>
  </details>
</section>

<script>
  import { recommendTaskSetup } from '../../lib/workbuddy-labs';

  const scenarios = {
    question: {
      label: '解释这份报告讲了什么，不修改文件',
      modifiesFiles: false,
      multiStep: false,
      highRisk: false,
      reversible: true,
    },
    multi: {
      label: '把五份表格合并、生成图表并保存',
      modifiesFiles: true,
      multiStep: true,
      highRisk: false,
      reversible: true,
    },
    simple: {
      label: '把一份文档另存为 Markdown',
      modifiesFiles: true,
      multiStep: false,
      highRisk: false,
      reversible: true,
    },
    risky: {
      label: '批量删除原始资料中的重复文件',
      modifiesFiles: true,
      multiStep: true,
      highRisk: true,
      reversible: false,
    },
  };

  document.querySelectorAll<HTMLElement>('[data-mode-permission-lab]').forEach((root) => {
    const select = root.querySelector<HTMLSelectElement>('[data-scenario]');
    const scenarioCopy = root.querySelector<HTMLElement>('[data-scenario-copy]');
    const workMode = root.querySelector<HTMLElement>('[data-work-mode]');
    const permission = root.querySelector<HTMLElement>('[data-permission-mode]');
    const recommendation = root.querySelector<HTMLElement>('[data-recommendation]');
    const recommendationReason = root.querySelector<HTMLElement>('[data-recommendation-reason]');
    const planToggle = root.querySelector<HTMLInputElement>('[data-plan-toggle]');
    const askToggle = root.querySelector<HTMLInputElement>('[data-ask-toggle]');
    if (!select || !scenarioCopy || !workMode || !permission || !recommendation || !recommendationReason) return;

    const render = () => {
      const profile = scenarios[select.value as keyof typeof scenarios];
      const result = recommendTaskSetup(profile);
      scenarioCopy.textContent = profile.label;
      workMode.textContent = result.workMode;
      permission.textContent = result.permissionMode;
      recommendationReason.textContent = result.reason;
      if (planToggle) planToggle.checked = result.workMode === 'Plan';
      if (askToggle) askToggle.checked = result.workMode === 'Ask';
      recommendation.className = `wb-status decision-status ${profile.highRisk ? 'warning' : 'success'}`;
    };

    select.addEventListener('change', render);
    render();
  });
</script>

<style>
  .scenario-in-composer {
    color: var(--wb-client-text);
  }

  .scenario-in-composer p {
    margin: var(--space-1) 0 0;
    color: var(--wb-client-muted);
    font-size: var(--wb-client-text-size);
  }

  .scenario-label {
    color: var(--wb-client-subtle);
    font-size: var(--wb-client-tiny-text);
  }

  .decision-status strong {
    font-family: var(--font-mono);
    font-weight: var(--font-medium);
  }

  .full-access-note {
    margin-top: var(--space-5);
    padding: var(--space-4);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .full-access-note summary {
    cursor: pointer;
    font-weight: var(--font-medium);
  }

  .full-access-note p {
    margin: var(--space-3) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
</style>
