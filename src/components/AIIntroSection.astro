<script>
  // 翻转卡片
  document.querySelectorAll<HTMLElement>('.flip-card').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('flipped');
    });
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        card.classList.toggle('flipped');
      }
    });
    card.setAttribute('tabindex', '0');
    card.setAttribute('role', 'button');
    card.setAttribute('aria-label', card.querySelector('.card-name')?.textContent + '——点击翻看');
  });

  // 模拟对话
  const qas = [
    {
      q: '我完全不会编程，能用 AI 做出产品吗？',
      a: '可以。现在已经有大量非程序员用 Claude Code、Cursor 这类工具做出真实产品。你需要的不是会写代码，而是知道自己想做什么。'
    },
    {
      q: '帮我给 AI 资讯网站起个名字',
      a: '几个方向：① 晨讯 AI ② 灵鸟资讯 ③ 脉冲 Daily —— 你偏向哪种风格，我再细化？'
    },
    {
      q: 'AI 会不会有一天完全取代人类？',
      a: '这个问题我没办法确定地回答。但我能确定的是：善用 AI 的人，会比不用的人多出大量时间去做更重要的事。'
    },
    {
      q: '用中文还是英文跟 AI 说话，哪个效果更好？',
      a: '主流大模型对中英文的理解能力差距不大，用你更习惯的语言就好。复杂技术问题用英文有时能得到更精准的答案，但日常使用中文完全够用。'
    }
  ];

  let currentIdx = 0;

  function renderMsg(text: string, role: 'user' | 'ai') {
    const div = document.createElement('div');
    div.className = `msg msg-${role}`;
    div.textContent = text;
    return div;
  }

  function renderChat(idx: number) {
    const el = document.getElementById('chat-messages');
    if (!el) return;
    el.innerHTML = '';
    const qa = qas[idx];
    el.appendChild(renderMsg(qa.q, 'user'));

    // AI 回复用打字机效果
    const aiDiv = renderMsg('', 'ai');
    el.appendChild(aiDiv);
    let i = 0;
    const interval = setInterval(() => {
      aiDiv.textContent += qa.a[i];
      i++;
      if (i >= qa.a.length) clearInterval(interval);
    }, 18);
  }

  const nextBtn = document.getElementById('chat-next');
  nextBtn?.addEventListener('click', () => {
    currentIdx = (currentIdx + 1) % qas.length;
    renderChat(currentIdx);
  });

  renderChat(0);
</script>

