---
// 数据库登录过程逐步演示，纯原生 JS
---

<div class="ld-root">
  <div class="ld-layout">
    <div class="ld-form-col">
      <div class="ld-col-header">你的登录界面</div>
      <div class="ld-form">
        <div class="ld-field">
          <label class="ld-label" for="ldEmail">邮箱</label>
          <input class="ld-input" id="ldEmail" type="email" value="cesar@example.com" readonly />
        </div>
        <div class="ld-field">
          <label class="ld-label" for="ldPass">密码</label>
          <input class="ld-input" id="ldPass" type="password" value="••••••••" readonly />
        </div>
        <button class="ld-login-btn" id="ldLoginBtn" type="button">登录</button>
        <div class="ld-feedback" id="ldFeedback" aria-live="assertive"></div>
      </div>
    </div>

    <div class="ld-db-col">
      <div class="ld-col-header">数据库 · users 表</div>
      <div class="ld-table" aria-label="用户数据库表">
        <div class="ld-table-head">
          <span>email</span>
          <span>password_hash</span>
          <span>用户名</span>
        </div>
        <div class="ld-row" id="ldRow0" data-email="alice@example.com">
          <span class="ld-cell">alice@example.com</span>
          <span class="ld-cell ld-mono">$2b$10$aX...</span>
          <span class="ld-cell">Alice</span>
        </div>
        <div class="ld-row" id="ldRow1" data-email="bob@example.com">
          <span class="ld-cell">bob@example.com</span>
          <span class="ld-cell ld-mono">$2b$10$bY...</span>
          <span class="ld-cell">Bob</span>
        </div>
        <div class="ld-row" id="ldRow2" data-email="cesar@example.com">
          <span class="ld-cell">cesar@example.com</span>
          <span class="ld-cell ld-mono">$2b$10$cZ...</span>
          <span class="ld-cell">Cesar</span>
        </div>
        <div class="ld-row" id="ldRow3" data-email="diana@example.com">
          <span class="ld-cell">diana@example.com</span>
          <span class="ld-cell ld-mono">$2b$10$dW...</span>
          <span class="ld-cell">Diana</span>
        </div>
      </div>
    </div>
  </div>

  <div class="ld-steps" aria-live="polite">
    <div class="ld-step" id="ldStep" role="status"></div>
  </div>
</div>

<style>
  .ld-root {
    margin: var(--space-6) 0;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-primary);
  }

  .ld-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    min-height: 260px;
  }

  .ld-col-header {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-secondary);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
    border-bottom: 0.5px solid var(--color-border);
  }

  .ld-form-col {
    border-right: 0.5px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  .ld-form {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ld-field { display: flex; flex-direction: column; gap: var(--space-1); }

  .ld-label {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .ld-input {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
  }

  .ld-login-btn {
    padding: var(--space-2) var(--space-4);
    background: var(--color-text-info);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .ld-login-btn:hover:not(:disabled) { opacity: 0.85; }
  .ld-login-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .ld-feedback {
    font-size: var(--text-sm);
    min-height: 1.5rem;
    text-align: center;
  }

  .ld-feedback.success { color: var(--color-text-success); }
  .ld-feedback.error   { color: var(--color-text-danger); }

  .ld-db-col {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ld-table {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ld-table-head {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-2);
    font-size: 10px;
    font-weight: var(--font-medium);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 0.5px solid var(--color-border);
  }

  .ld-row {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-2);
    border-radius: var(--radius-sm);
    transition: background 0.3s, transform 0.2s;
  }

  .ld-row.scanning {
    background: var(--color-bg-warning);
    transform: translateX(2px);
  }

  .ld-row.found {
    background: var(--color-bg-success);
  }

  .ld-cell {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ld-row.found .ld-cell { color: var(--color-text-success); }

  .ld-mono { font-family: var(--font-mono); }

  .ld-steps {
    padding: var(--space-3) var(--space-4);
    border-top: 0.5px solid var(--color-border);
    background: var(--color-bg-secondary);
    min-height: 3rem;
    display: flex;
    align-items: center;
  }

  .ld-step {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 560px) {
    .ld-layout { grid-template-columns: 1fr; }
    .ld-form-col { border-right: none; border-bottom: 0.5px solid var(--color-border); }
    .ld-table-head,
    .ld-row { grid-template-columns: 1.5fr 1fr; }
    .ld-cell:last-child,
    .ld-table-head span:last-child { display: none; }
  }
</style>

<script>
  (function () {
    var loginBtn  = document.getElementById('ldLoginBtn');
    var feedbackEl = document.getElementById('ldFeedback');
    var stepEl    = document.getElementById('ldStep');
    var rows      = [
      document.getElementById('ldRow0'),
      document.getElementById('ldRow1'),
      document.getElementById('ldRow2'),
      document.getElementById('ldRow3')
    ];

    if (!loginBtn || !feedbackEl || !stepEl) return;

    var targetRow = 2;
    var timers = [];

    function clearRows() {
      rows.forEach(function (r) {
        if (r) r.className = 'ld-row';
      });
    }

    function after(ms, fn) {
      var t = setTimeout(fn, ms);
      timers.push(t);
    }

    loginBtn.addEventListener('click', function () {
      timers.forEach(clearTimeout);
      timers = [];
      loginBtn.disabled = true;
      feedbackEl.textContent = '';
      feedbackEl.className = 'ld-feedback';
      clearRows();

      stepEl.textContent = '收到请求，开始在用户表里查找这个邮箱……';

      var delay = 500;
      for (var i = 0; i <= targetRow; i++) {
        (function (idx, d) {
          after(d, function () {
            clearRows();
            var row = rows[idx];
            if (!row) return;
            row.className = idx === targetRow ? 'ld-row found' : 'ld-row scanning';
            if (idx < targetRow) {
              stepEl.textContent = '第 ' + (idx + 1) + ' 行：' + row.dataset.email + '——不是，继续找……';
            } else {
              stepEl.textContent = '找到了！邮箱匹配。现在对比密码……';
            }
          });
        })(i, delay);
        delay += 700;
      }

      after(delay + 400, function () {
        stepEl.textContent = '密码验证通过（服务器对比哈希值，不是明文）。返回登录成功！';
        feedbackEl.textContent = '✓ 欢迎回来，Cesar！';
        feedbackEl.className = 'ld-feedback success';
        after(2000, function () {
          loginBtn.disabled = false;
        });
      });
    });
  })();
</script>
