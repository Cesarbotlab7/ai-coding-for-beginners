---
// DNS 查询四步动画，纯原生 JS
---

<div class="dns-root">
  <div class="dns-input-row">
    <span class="dns-browser-icon" aria-hidden="true">💻</span>
    <div class="dns-url-bar">
      <span class="dns-url-label">你输入：</span>
      <span class="dns-url-val">ai-hot.news</span>
    </div>
    <button class="dns-start-btn" id="dnsStartBtn" type="button">开始解析 →</button>
  </div>

  <div class="dns-steps" id="dnsSteps" aria-live="polite">
    <div class="dns-step" id="dnsS0" data-step="0">
      <div class="dns-step-icon" aria-hidden="true">📋</div>
      <div class="dns-step-body">
        <div class="dns-step-title">第一步：查本地缓存</div>
        <div class="dns-step-desc">浏览器先看看自己有没有记过这个域名的 IP。如果上次访问过、还没过期，直接用缓存，不用往下查。</div>
        <div class="dns-step-result" id="dnsR0">→ 没有缓存，继续查</div>
      </div>
    </div>

    <div class="dns-connector" aria-hidden="true">↓</div>

    <div class="dns-step" id="dnsS1" data-step="1">
      <div class="dns-step-icon" aria-hidden="true">🌐</div>
      <div class="dns-step-body">
        <div class="dns-step-title">第二步：问 ISP DNS 服务器</div>
        <div class="dns-step-desc">你的网络运营商（联通/移动/电信）有自己的 DNS 服务器，通常能回答常见域名。</div>
        <div class="dns-step-result" id="dnsR1">→ 它也不知道，继续问上级</div>
      </div>
    </div>

    <div class="dns-connector" aria-hidden="true">↓</div>

    <div class="dns-step" id="dnsS2" data-step="2">
      <div class="dns-step-icon" aria-hidden="true">🗂️</div>
      <div class="dns-step-body">
        <div class="dns-step-title">第三步：问根 DNS 服务器</div>
        <div class="dns-step-desc">根服务器全球只有 13 组，是整个 DNS 系统的入口。它不知道 IP，但知道".news"域名该去哪个服务器查。</div>
        <div class="dns-step-result" id="dnsR2">→ ".news 的权威 DNS 在这里"</div>
      </div>
    </div>

    <div class="dns-connector" aria-hidden="true">↓</div>

    <div class="dns-step" id="dnsS3" data-step="3">
      <div class="dns-step-icon" aria-hidden="true">📍</div>
      <div class="dns-step-body">
        <div class="dns-step-title">第四步：问权威 DNS 服务器</div>
        <div class="dns-step-desc">这是你在买域名时配置 DNS 记录的那台服务器。它知道"ai-hot.news"指向哪个 IP——这是你设置的 A 记录。</div>
        <div class="dns-step-result" id="dnsR3">→ IP 是 <code>76.223.126.88</code></div>
      </div>
    </div>
  </div>

  <div class="dns-final" id="dnsFinal" hidden>
    <div class="dns-final-inner">
      <span class="dns-final-icon" aria-hidden="true">🔒</span>
      <div class="dns-final-text">
        <strong>拿到 IP 了！</strong> 浏览器开始向 <code>76.223.126.88</code> 发起 HTTPS 连接——
        TLS 握手完成后，数据全程加密传输，地址栏显示那把小锁。
      </div>
    </div>
    <button class="dns-reset-btn" id="dnsResetBtn" type="button">再看一遍</button>
  </div>
</div>

<style>
  .dns-root {
    margin: var(--space-6) 0;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-primary);
  }

  .dns-input-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    border-bottom: 0.5px solid var(--color-border);
    flex-wrap: wrap;
  }

  .dns-browser-icon { font-size: 1.2rem; }

  .dns-url-bar {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-width: 180px;
  }

  .dns-url-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .dns-url-val {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .dns-start-btn {
    padding: var(--space-2) var(--space-4);
    background: var(--color-text-info);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .dns-start-btn:hover:not(:disabled) { opacity: 0.85; }
  .dns-start-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .dns-steps {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dns-step {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    opacity: 0.35;
    transition: opacity 0.4s, background 0.4s;
  }

  .dns-step.dns-active {
    opacity: 1;
    background: var(--color-bg-info);
  }

  .dns-step.dns-done {
    opacity: 0.8;
  }

  .dns-step-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .dns-step-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .dns-step-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
  }

  .dns-step-desc {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .dns-step-result {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-info);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .dns-step.dns-active .dns-step-result,
  .dns-step.dns-done .dns-step-result {
    opacity: 1;
  }

  .dns-step-result code {
    background: var(--color-bg-secondary);
    padding: 1px 4px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
  }

  .dns-connector {
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: var(--text-lg);
    line-height: 1.2;
    padding: var(--space-1) 0;
  }

  .dns-final {
    margin: var(--space-4);
    animation: dnsFadeUp 0.4s ease both;
  }

  @keyframes dnsFadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dns-final-inner {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-4);
    background: var(--color-bg-success);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
  }

  .dns-final-icon { font-size: 1.4rem; flex-shrink: 0; }

  .dns-final-text {
    font-size: var(--text-sm);
    color: var(--color-text-success);
    line-height: 1.65;
  }

  .dns-final-text code {
    font-family: var(--font-mono);
    background: rgba(0,0,0,0.05);
    padding: 1px 4px;
    border-radius: var(--radius-sm);
  }

  .dns-reset-btn {
    display: block;
    width: 100%;
    padding: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-primary);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .dns-reset-btn:hover { border-color: var(--color-text-info); color: var(--color-text-info); }
</style>

<script>
  (function () {
    var startBtn = document.getElementById('dnsStartBtn');
    var finalEl  = document.getElementById('dnsFinal');
    var resetBtn = document.getElementById('dnsResetBtn');
    var stepEls  = [
      document.getElementById('dnsS0'),
      document.getElementById('dnsS1'),
      document.getElementById('dnsS2'),
      document.getElementById('dnsS3')
    ];

    if (!startBtn || !finalEl || !resetBtn) return;

    var timers = [];

    function after(ms, fn) {
      var t = setTimeout(fn, ms);
      timers.push(t);
    }

    function reset() {
      timers.forEach(clearTimeout);
      timers = [];
      stepEls.forEach(function (el) {
        if (el) el.className = 'dns-step';
      });
      finalEl.hidden = true;
      startBtn.disabled = false;
    }

    function runStep(idx) {
      var el = stepEls[idx];
      if (!el) return;
      stepEls.forEach(function (s, i) {
        if (!s) return;
        s.className = i < idx ? 'dns-step dns-done' : (i === idx ? 'dns-step dns-active' : 'dns-step');
      });

      if (idx < stepEls.length - 1) {
        after(1600, function () { runStep(idx + 1); });
      } else {
        after(1600, function () {
          stepEls.forEach(function (s) { if (s) s.className = 'dns-step dns-done'; });
          finalEl.hidden = false;
        });
      }
    }

    startBtn.addEventListener('click', function () {
      timers.forEach(clearTimeout);
      timers = [];
      finalEl.hidden = true;
      startBtn.disabled = true;
      stepEls.forEach(function (el) { if (el) el.className = 'dns-step'; });
      after(300, function () { runStep(0); });
    });

    resetBtn.addEventListener('click', reset);
  })();
</script>
