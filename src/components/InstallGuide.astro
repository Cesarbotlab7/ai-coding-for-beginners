<div class="install-guide" id="install-guide">

  <div class="progress-nav" role="list" aria-label="安装步骤">
    <button class="step-nav-btn active" data-step="0" role="listitem" aria-current="step">
      <span class="step-num">1</span>
      <span class="step-nav-label">Node.js</span>
    </button>
    <div class="step-connector" aria-hidden="true"></div>
    <button class="step-nav-btn" data-step="1" role="listitem">
      <span class="step-num">2</span>
      <span class="step-nav-label">安装</span>
    </button>
    <div class="step-connector" aria-hidden="true"></div>
    <button class="step-nav-btn" data-step="2" role="listitem">
      <span class="step-num">3</span>
      <span class="step-nav-label">API Key</span>
    </button>
    <div class="step-connector" aria-hidden="true"></div>
    <button class="step-nav-btn" data-step="3" role="listitem">
      <span class="step-num">4</span>
      <span class="step-nav-label">启动</span>
    </button>
  </div>

  <div class="step-panels">

    <!-- Step 0: Node.js -->
    <div class="step-panel active" data-panel="0">
      <p class="step-eyebrow">步骤 1 / 4</p>
      <h3 class="step-title">安装 Node.js</h3>
      <p class="step-body">后面创建 Astro 项目会用到 <code>node</code> 和 <code>npm</code>。npm 随 Node.js 一起来。去官网下载安装包，一路「Continue」就行，不需要任何配置。</p>

      <a class="step-link-btn" href="https://nodejs.org" target="_blank" rel="noopener noreferrer">
        去下载 Node.js →
      </a>

      <p class="step-body" style="margin-top: var(--space-5);">装完后，打开终端（Mac：⌘ + 空格，搜索「终端」），输入这条命令验证：</p>

      <div class="cmd-block">
        <span class="cmd-text" id="cmd-0">node --version</span>
        <button class="copy-btn" data-copy="node --version" aria-label="复制命令">复制</button>
      </div>

      <div class="terminal-output" id="out-0" aria-live="polite">
        <button class="run-btn" data-run="0">▶ 模拟运行，看看输出长什么样</button>
      </div>

      <button class="next-btn" data-next="1">✓ 我装好了，下一步</button>
    </div>

    <!-- Step 1: Install Claude Code -->
    <div class="step-panel" data-panel="1">
      <p class="step-eyebrow">步骤 2 / 4</p>
      <h3 class="step-title">安装 Claude Code</h3>
      <p class="step-body">在终端里粘贴下面这条命令，回车。它会从 Claude 官网下载安装器。安装命令以后可能变化，真实操作前以官网显示为准。</p>

      <div class="cmd-block">
        <span class="cmd-text" id="cmd-1">curl -fsSL https://claude.ai/install.sh | bash</span>
        <button class="copy-btn" data-copy="curl -fsSL https://claude.ai/install.sh | bash" aria-label="复制命令">复制</button>
      </div>

      <div class="terminal-output" id="out-1" aria-live="polite">
        <button class="run-btn" data-run="1">▶ 模拟运行，看看输出长什么样</button>
      </div>

      <button class="next-btn" data-next="2">✓ 安装完成，下一步</button>
    </div>

    <!-- Step 2: API Key -->
    <div class="step-panel" data-panel="2">
      <p class="step-eyebrow">步骤 3 / 4</p>
      <h3 class="step-title">登录账号</h3>
      <p class="step-body">Claude Code 需要验证你的身份。有两种方式，选一种就行：</p>

      <div class="api-key-steps">
        <div class="api-step">
          <span class="api-step-num" style="font-size:var(--text-base);">A</span>
          <span>
            <strong>Claude.ai 账号或订阅</strong><br>
            使用账号方式时，启动 Claude Code 会自动打开浏览器让你登录 claude.ai，授权即可。<strong>不需要单独拿 API Key。</strong>
          </span>
        </div>
        <div class="api-step">
          <span class="api-step-num" style="font-size:var(--text-base);">B</span>
          <span>
            <strong>Anthropic API Key</strong>（按量付费）<br>
            去控制台注册账号 → 先充值 → 创建 Key（以 <code>sk-ant-</code> 开头），启动时粘贴进去。
          </span>
        </div>
      </div>

      <a class="step-link-btn" href="https://claude.ai" target="_blank" rel="noopener noreferrer">
        打开 Claude.ai →
      </a>

      <div class="tip-box">
        <span class="tip-icon" aria-hidden="true">⚠️</span>
        <p>AI 编程工具的套餐、额度和价格变化很快。不要背别人截图里的数字，付费前打开官网确认一次。</p>
      </div>

      <button class="next-btn" data-next="3">✓ 我搞定了，下一步</button>
    </div>

    <!-- Step 3: First launch -->
    <div class="step-panel" data-panel="3">
      <p class="step-eyebrow">步骤 4 / 4</p>
      <h3 class="step-title">启动 Claude Code</h3>
      <p class="step-body">在终端里进入你的项目文件夹（或者任意一个文件夹），然后输入：</p>

      <div class="cmd-block">
        <span class="cmd-text" id="cmd-3">claude</span>
        <button class="copy-btn" data-copy="claude" aria-label="复制命令">复制</button>
      </div>

      <p class="step-body" style="margin-top: var(--space-4);">第一次启动会自动打开浏览器完成授权，授权完成后终端就进入对话界面。直接用中文描述你想做的事，回车发送。</p>

      <div class="terminal-output" id="out-3" aria-live="polite">
        <button class="run-btn" data-run="3">▶ 模拟运行，看看启动长什么样</button>
      </div>

      <div class="success-state" id="success-state" style="display:none;">
        <span class="success-icon" aria-hidden="true">🎉</span>
        <p class="success-text">Claude Code 已经在你的电脑上跑起来了。<br>下一章我们看它能帮你干什么。</p>
      </div>

      <button class="next-btn finish-btn" data-next="done">✓ 启动成功，我准备好了</button>
    </div>

  </div>
</div>

<style>
  .install-guide {
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-bg-primary);
    margin: var(--space-6) 0;
  }

  /* ── Progress nav ── */
  .progress-nav {
    display: flex;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 0.5px solid var(--color-border);
    background: var(--color-bg-secondary);
    gap: 0;
  }

  .step-nav-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
    transition: background 0.12s;
    flex-shrink: 0;
  }

  .step-nav-btn:hover {
    background: var(--color-bg-tertiary);
  }

  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: var(--font-medium);
    background: var(--color-bg-tertiary);
    color: var(--color-text-tertiary);
    border: 1.5px solid var(--color-border);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .step-nav-btn.active .step-num {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
    border-color: var(--color-text-primary);
  }

  .step-nav-btn.done .step-num {
    background: var(--color-bg-success);
    color: var(--color-text-success);
    border-color: var(--color-text-success);
  }

  .step-nav-btn.done .step-num::after {
    content: '✓';
  }

  .step-nav-btn.done .step-num > * {
    display: none;
  }

  .step-nav-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  .step-nav-btn.active .step-nav-label {
    color: var(--color-text-primary);
    font-weight: var(--font-medium);
  }

  .step-connector {
    flex: 1;
    height: 1px;
    background: var(--color-border);
    margin-bottom: 16px;
    min-width: var(--space-3);
  }

  /* ── Step panels ── */
  .step-panels {
    padding: var(--space-6);
  }

  .step-panel {
    display: none;
    flex-direction: column;
    gap: var(--space-4);
    animation: fadeIn 0.2s ease;
  }

  .step-panel.active {
    display: flex;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .step-eyebrow {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    margin: 0;
  }

  .step-title {
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin: 0;
  }

  .step-body {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
  }

  .step-body code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--color-bg-tertiary);
    padding: 1px 5px;
    border-radius: var(--radius-sm);
  }

  /* ── Command block ── */
  .cmd-block {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: #1a1a18;
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
  }

  .cmd-text {
    flex: 1;
    color: #c8ffa7;
    font-size: var(--text-sm);
    user-select: all;
  }

  .cmd-text::before {
    content: '$ ';
    color: #888780;
  }

  .copy-btn {
    background: none;
    border: 0.5px solid #444;
    color: #888780;
    font-size: var(--text-xs);
    padding: 3px var(--space-2);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: border-color 0.12s, color 0.12s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    border-color: #888;
    color: #ccc;
  }

  .copy-btn.copied {
    color: #c8ffa7;
    border-color: #c8ffa7;
  }

  /* ── Terminal output ── */
  .terminal-output {
    background: #1a1a18;
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    min-height: 60px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .run-btn {
    background: none;
    border: 0.5px dashed #444;
    color: #888780;
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-mono);
    text-align: left;
    transition: border-color 0.12s, color 0.12s;
    align-self: flex-start;
  }

  .run-btn:hover {
    border-color: #888;
    color: #ccc;
  }

  .terminal-line {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    white-space: pre;
  }

  /* ── API key steps ── */
  .api-key-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }

  .api-step {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .api-step-num {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  .api-step code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--color-bg-tertiary);
    padding: 1px 5px;
    border-radius: var(--radius-sm);
  }

  .api-step strong {
    color: var(--color-text-primary);
    font-weight: var(--font-medium);
  }

  /* ── Link button ── */
  .step-link-btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    text-decoration: none;
    font-weight: var(--font-medium);
    transition: background 0.12s;
    align-self: flex-start;
  }

  .step-link-btn:hover {
    background: var(--color-bg-tertiary);
  }

  /* ── Tip box ── */
  .tip-box {
    display: flex;
    gap: var(--space-3);
    background: var(--color-bg-info);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .tip-icon {
    font-size: 18px;
    flex-shrink: 0;
    line-height: 1.6;
  }

  .tip-box p {
    font-size: var(--text-sm);
    color: var(--color-text-info);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Next button ── */
  .next-btn {
    align-self: flex-start;
    padding: var(--space-3) var(--space-5);
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: opacity 0.12s;
    margin-top: var(--space-2);
  }

  .next-btn:hover {
    opacity: 0.85;
  }

  /* ── Success state ── */
  .success-state {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    background: var(--color-bg-success);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .success-icon {
    font-size: 28px;
    line-height: 1;
    flex-shrink: 0;
  }

  .success-text {
    font-size: var(--text-base);
    color: var(--color-text-success);
    line-height: 1.75;
    margin: 0;
  }

  @media (max-width: 640px) {
    .step-panels {
      padding: var(--space-5) var(--space-4);
    }

    .step-nav-label {
      display: none;
    }

    .step-connector {
      min-width: var(--space-2);
    }
  }
</style>

<script>
  const outputs: Record<number, { type: string; text: string }[]> = {
    0: [
      { type: 'prompt', text: '$ node --version' },
      { type: 'ok',     text: 'v20.11.0' },
      { type: 'dim',    text: '' },
      { type: 'dim',    text: '# 看到版本号就对了。如果提示 command not found，说明还没装好。' },
    ],
    1: [
      { type: 'prompt', text: '$ curl -fsSL https://claude.ai/install.sh | bash' },
      { type: 'dim',    text: 'Downloading Claude Code installer...' },
      { type: 'out',    text: 'Installing Claude Code...' },
      { type: 'dim',    text: '' },
      { type: 'ok',     text: '✓ Claude Code installed successfully' },
    ],
    3: [
      { type: 'prompt', text: '$ claude' },
      { type: 'dim',    text: '' },
      { type: 'ok',     text: ' * Welcome to Claude Code!' },
      { type: 'dim',    text: '' },
      { type: 'dim',    text: '   /help for help, /exit to exit' },
      { type: 'dim',    text: '   cwd: ~/my-project' },
      { type: 'dim',    text: '' },
      { type: 'out',    text: ' > What would you like to do?' },
      { type: 'dim',    text: '   (用中文说也可以，直接描述你想做的事)' },
    ],
  };

  // 模拟运行按钮
  document.querySelectorAll<HTMLButtonElement>('.run-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.run ?? '0');
      const container = btn.parentElement!;
      const lines = outputs[step];
      if (!lines) return;

      btn.remove();

      let i = 0;
      function addLine() {
        if (i >= lines.length) return;
        const div = document.createElement('div');
        div.className = `terminal-line ${lines[i].type}`;
        div.textContent = lines[i].text;
        container.appendChild(div);
        i++;
        setTimeout(addLine, lines[i - 1].text.length > 0 ? 120 : 40);
      }
      addLine();
    });
  });

  // 复制按钮
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = '已复制 ✓';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = '复制';
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  });

  // 步骤导航
  function goToStep(stepIdx: number) {
    const panels = document.querySelectorAll<HTMLElement>('.step-panel');
    const navBtns = document.querySelectorAll<HTMLElement>('.step-nav-btn');

    panels.forEach((p, i) => {
      p.classList.toggle('active', i === stepIdx);
    });

    navBtns.forEach((b, i) => {
      b.classList.remove('active');
      if (i < stepIdx) b.classList.add('done');
      if (i === stepIdx) {
        b.classList.add('active');
        b.setAttribute('aria-current', 'step');
      } else {
        b.removeAttribute('aria-current');
      }
    });
  }

  // 下一步按钮
  document.querySelectorAll<HTMLButtonElement>('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = btn.dataset.next;
      if (next === 'done') {
        // 显示成功状态
        const successEl = document.getElementById('success-state');
        if (successEl) successEl.style.display = 'flex';
        btn.style.display = 'none';
        // 把第4步导航也标为done
        const navBtns = document.querySelectorAll<HTMLElement>('.step-nav-btn');
        navBtns[3]?.classList.add('done');
        navBtns[3]?.classList.remove('active');
      } else {
        goToStep(parseInt(next ?? '0'));
      }
    });
  });

  // 导航栏点击跳步
  document.querySelectorAll<HTMLButtonElement>('.step-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step ?? '0');
      goToStep(step);
    });
  });
</script>

<style is:global>
  .terminal-line { font-family: "SF Mono", Menlo, Monaco, monospace; font-size: 13px; line-height: 1.6; white-space: pre; }
  .terminal-line.out    { color: #e8e6df; }
  .terminal-line.ok     { color: #a8ff87; }
  .terminal-line.dim    { color: #b0aea6; }
  .terminal-line.prompt { color: #a8ff87; }
</style>
