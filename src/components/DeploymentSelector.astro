---
// 部署方案选择器，根据用户回答推荐最合适的平台
---

<div class="ds-root" id="dsRoot">
  <div class="ds-questions" id="dsQuestions">
    <div class="ds-question" id="dsQ0" data-step="0">
      <p class="ds-q-text">你在做什么类型的项目？</p>
      <div class="ds-options">
        <button class="ds-opt" data-q="0" data-v="blog" type="button">个人博客 / 文档</button>
        <button class="ds-opt" data-q="0" data-v="tool" type="button">小工具 / 展示页</button>
        <button class="ds-opt" data-q="0" data-v="app" type="button">需要数据库 / 后端</button>
      </div>
    </div>

    <div class="ds-question ds-hidden" id="dsQ1" data-step="1">
      <p class="ds-q-text">大概每天有多少人访问？</p>
      <div class="ds-options">
        <button class="ds-opt" data-q="1" data-v="small" type="button">不多，几十到几百</button>
        <button class="ds-opt" data-q="1" data-v="medium" type="button">几千到几万</button>
        <button class="ds-opt" data-q="1" data-v="large" type="button">很多，几十万以上</button>
      </div>
    </div>

    <div class="ds-question ds-hidden" id="dsQ2" data-step="2">
      <p class="ds-q-text">需要自己控制服务器配置吗？</p>
      <div class="ds-options">
        <button class="ds-opt" data-q="2" data-v="no" type="button">不需要，越省事越好</button>
        <button class="ds-opt" data-q="2" data-v="yes" type="button">需要，我想自己配置</button>
      </div>
    </div>
  </div>

  <div class="ds-progress" id="dsProgress" aria-live="polite">
    <div class="ds-step-dots">
      <span class="ds-dot ds-dot--active" id="dsDot0"></span>
      <span class="ds-dot" id="dsDot1"></span>
      <span class="ds-dot" id="dsDot2"></span>
    </div>
  </div>

  <div class="ds-result" id="dsResult" hidden aria-live="polite">
    <div class="ds-result-inner" id="dsResultInner">
      <div class="ds-result-title" id="dsResultTitle"></div>
      <div class="ds-result-desc" id="dsResultDesc"></div>
      <div class="ds-cost-row">
        <span class="ds-cost-label">预估月费</span>
        <span class="ds-cost-value" id="dsResultCost"></span>
      </div>
      <div class="ds-examples" id="dsResultExamples"></div>
    </div>
    <button class="ds-retry" id="dsRetry" type="button">重新选择</button>
  </div>
</div>

<style>
  .ds-root {
    margin: var(--space-6) 0;
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--color-border);
  }

  .ds-question { display: flex; flex-direction: column; gap: var(--space-3); }
  .ds-hidden { display: none; }

  .ds-q-text {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin: 0;
  }

  .ds-options {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .ds-opt {
    padding: var(--space-2) var(--space-4);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-primary);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .ds-opt:hover {
    border-color: var(--color-text-info);
    color: var(--color-text-info);
    background: var(--color-bg-info);
  }

  .ds-progress {
    margin-top: var(--space-4);
    display: flex;
    justify-content: center;
  }

  .ds-step-dots {
    display: flex;
    gap: var(--space-2);
  }

  .ds-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border-secondary);
    transition: background 0.3s;
  }

  .ds-dot--active { background: var(--color-text-info); }

  .ds-result {
    animation: dsFadeUp 0.3s ease both;
  }

  @keyframes dsFadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ds-result-inner {
    background: var(--color-bg-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-3);
  }

  .ds-result-title {
    font-size: var(--text-md);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .ds-result-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-3);
  }

  .ds-cost-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-success);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
  }

  .ds-cost-label {
    font-size: var(--text-xs);
    color: var(--color-text-success);
    font-weight: var(--font-medium);
  }

  .ds-cost-value {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-success);
  }

  .ds-examples {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.6;
  }

  .ds-retry {
    display: block;
    width: 100%;
    padding: var(--space-2);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .ds-retry:hover { border-color: var(--color-text-info); color: var(--color-text-info); }
</style>

<script>
  (function () {
    var answers = {};
    var currentStep = 0;

    var recommendations = {
      blog_small_no:  { title: 'GitHub Pages 或 Cloudflare Pages', desc: '纯静态托管，零配置，直接把文件推上去就好。适合博客、文档、作品集。', cost: '¥0 / 月（永久免费）', examples: '适用服务：GitHub Pages / Cloudflare Pages / Vercel（静态模式）' },
      blog_small_yes: { title: 'GitHub Pages 或 Cloudflare Pages', desc: '博客和文档很少需要自定义服务器配置，建议还是用托管平台，节省时间。', cost: '¥0 / 月', examples: '适用服务：GitHub Pages / Netlify' },
      blog_medium_no: { title: 'Vercel 或 Netlify 免费计划', desc: '流量上来了，Vercel 的 CDN 也能扛。等到超出免费额度再付费升级。', cost: '¥0-50 / 月', examples: '适用服务：Vercel Pro / Netlify Pro' },
      tool_small_no:  { title: 'Vercel 免费计划', desc: '小工具和展示页，Vercel 一键部署，自动 HTTPS，全球 CDN，免费额度够用。', cost: '¥0 / 月', examples: '适用服务：Vercel / Netlify / Render（免费层）' },
      tool_medium_no: { title: 'Vercel 或 Railway', desc: '如果有轻量后端逻辑，Railway 的免费/付费方案性价比高，不用配置 Linux。', cost: '¥0-30 / 月', examples: '适用服务：Vercel + Supabase 组合 / Railway' },
      app_small_no:   { title: 'Vercel + Supabase', desc: '前端用 Vercel，数据库用 Supabase，两者都有免费额度，个人项目月费接近零。这也是 AI 资讯平台现在的架构。', cost: '¥0-10 / 月', examples: '✓ 这也是这个 AI 资讯平台的部署方案' },
      app_medium_no:  { title: 'Vercel + Supabase Pro', desc: '数据量上来了，升级 Supabase Pro。Vercel 的免费额度通常还够用一段时间。', cost: '¥70-150 / 月', examples: '适用服务：Vercel + Supabase Pro / PlanetScale' },
      app_small_yes:  { title: '腾讯云或阿里云轻量服务器', desc: '如果想自己配 Nginx、Node、Python 环境，轻量服务器是入门选择。需要 ICP 备案才能绑自定义域名（大陆用户）。', cost: '¥30-80 / 月', examples: '适用服务：腾讯云轻量 / 阿里云 ECS / 海外选 Hetzner' },
      app_large_no:   { title: '云服务托管（需评估规模）', desc: '几十万访问量以上，需要根据具体情况评估。通常是 Vercel Enterprise 或自建 k8s，成本差异很大。', cost: '¥500+ / 月起', examples: '适用服务：Vercel Enterprise / AWS / Cloudflare Workers' },
      app_large_yes:  { title: '自建云服务器集群', desc: '这个规模需要专业的运维方案。建议先找技术合伙人，不是靠一个教程能解决的。', cost: '因规模而异', examples: '适用服务：AWS / 阿里云 / 腾讯云 ECS 集群' },
    };

    function getKey() {
      var t = answers[0] || 'tool';
      var v = answers[1] || 'small';
      var c = answers[2] || 'no';
      var key = t + '_' + v + '_' + c;
      if (recommendations[key]) return key;
      return t + '_small_no';
    }

    var questions = [
      document.getElementById('dsQ0'),
      document.getElementById('dsQ1'),
      document.getElementById('dsQ2')
    ];
    var dots = [
      document.getElementById('dsDot0'),
      document.getElementById('dsDot1'),
      document.getElementById('dsDot2')
    ];
    var resultEl       = document.getElementById('dsResult');
    var resultTitle    = document.getElementById('dsResultTitle');
    var resultDesc     = document.getElementById('dsResultDesc');
    var resultCost     = document.getElementById('dsResultCost');
    var resultExamples = document.getElementById('dsResultExamples');
    var retryBtn       = document.getElementById('dsRetry');

    if (!resultEl || !resultTitle || !resultDesc || !resultCost || !resultExamples || !retryBtn) return;

    function showStep(step) {
      questions.forEach(function (q, i) {
        if (!q) return;
        q.className = i === step ? 'ds-question' : 'ds-question ds-hidden';
      });
      dots.forEach(function (d, i) {
        if (!d) return;
        d.className = i <= step ? 'ds-dot ds-dot--active' : 'ds-dot';
      });
      currentStep = step;
    }

    function showResult() {
      questions.forEach(function (q) { if (q) q.className = 'ds-question ds-hidden'; });
      var key = getKey();
      var rec = recommendations[key];
      resultTitle.textContent    = rec.title;
      resultDesc.textContent     = rec.desc;
      resultCost.textContent     = rec.cost;
      resultExamples.textContent = rec.examples;
      resultEl.hidden = false;
    }

    document.querySelectorAll('.ds-opt').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var q = parseInt(btn.dataset.q, 10);
        var v = btn.dataset.v;
        answers[q] = v;

        if (q === 0) { showStep(1); }
        else if (q === 1) { showStep(2); }
        else { showResult(); }
      });
    });

    retryBtn.addEventListener('click', function () {
      answers = {};
      resultEl.hidden = true;
      showStep(0);
    });
  })();
</script>
