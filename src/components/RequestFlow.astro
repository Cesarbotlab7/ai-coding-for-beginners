---
// 请求-响应旅程追踪动画，纯原生 JS
---

<section class="rf-root" aria-label="请求-响应旅程演示">
  <div class="rf-action-row">
    <p class="rf-prompt">点这个按钮，然后看看背后发生了什么：</p>
    <button class="rf-btn" id="rfStartBtn" type="button">刷新 AI 资讯</button>
  </div>

  <div class="rf-stage">
    <div class="rf-nodes" role="img" aria-label="请求从浏览器出发，经过互联网和服务器，到数据库，再回到浏览器">
      <div class="rf-node" id="rfN0">
        <div class="rf-node-icon" aria-hidden="true">💻</div>
        <div class="rf-node-name">你的浏览器</div>
      </div>
      <div class="rf-connector" id="rfC01" aria-hidden="true">
        <svg width="36" height="14" viewBox="0 0 36 14" fill="none"><line x1="0" y1="7" x2="28" y2="7" stroke="currentColor" stroke-width="1.5"/><polyline points="22,2 30,7 22,12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/></svg>
      </div>
      <div class="rf-node" id="rfN1">
        <div class="rf-node-icon" aria-hidden="true">🌐</div>
        <div class="rf-node-name">互联网</div>
      </div>
      <div class="rf-connector" id="rfC12" aria-hidden="true">
        <svg width="36" height="14" viewBox="0 0 36 14" fill="none"><line x1="0" y1="7" x2="28" y2="7" stroke="currentColor" stroke-width="1.5"/><polyline points="22,2 30,7 22,12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/></svg>
      </div>
      <div class="rf-node" id="rfN2">
        <div class="rf-node-icon" aria-hidden="true">🖥️</div>
        <div class="rf-node-name">服务器</div>
      </div>
      <div class="rf-connector" id="rfC23" aria-hidden="true">
        <svg width="36" height="14" viewBox="0 0 36 14" fill="none"><line x1="0" y1="7" x2="28" y2="7" stroke="currentColor" stroke-width="1.5"/><polyline points="22,2 30,7 22,12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/></svg>
      </div>
      <div class="rf-node" id="rfN3">
        <div class="rf-node-icon" aria-hidden="true">🗄️</div>
        <div class="rf-node-name">数据库</div>
      </div>
    </div>

    <div class="rf-desc" id="rfDesc" aria-live="polite" role="status">
      准备好了，点上面的按钮开始。
    </div>
  </div>

  <div class="rf-result" id="rfResult" hidden>
    <div class="rf-card">
      <div class="rf-card-meta">
        <span class="rf-card-tag">arXiv</span>
        <span class="rf-card-time">刚刚</span>
      </div>
      <p class="rf-card-title">大型语言模型在代码推理能力上的新进展</p>
      <p class="rf-card-note">↑ 数据库里存着这条记录，服务器把它取出来，浏览器把它画成了这张卡片。</p>
    </div>
    <button class="rf-reset-btn" id="rfResetBtn" type="button">再看一遍</button>
  </div>
</section>

<style>
  .rf-root {
    margin: var(--space-6) 0;
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--color-border);
  }

  .rf-action-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .rf-prompt {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .rf-btn {
    padding: var(--space-2) var(--space-4);
    background: var(--color-text-info);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .rf-btn:hover:not(:disabled) { opacity: 0.85; }
  .rf-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .rf-stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .rf-nodes {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .rf-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-3);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
    min-width: 72px;
    transition: border-color 0.3s, background 0.3s, transform 0.2s;
  }

  .rf-node.rf-active {
    border-color: var(--color-text-info);
    background: var(--color-bg-info);
    transform: translateY(-3px);
  }

  .rf-node-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .rf-node-name {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-tertiary);
    text-align: center;
    white-space: nowrap;
  }

  .rf-node.rf-active .rf-node-name {
    color: var(--color-text-info);
  }

  .rf-connector {
    color: var(--color-border-secondary);
    display: flex;
    align-items: center;
    padding: 0;
    transition: color 0.3s;
    flex-shrink: 0;
  }

  .rf-connector.rf-active {
    color: var(--color-text-info);
  }

  .rf-desc {
    min-height: 4rem;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-primary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.75;
    transition: border-color 0.3s, color 0.3s;
  }

  .rf-desc.rf-active {
    border-left-color: var(--color-text-info);
    color: var(--color-text-primary);
  }

  .rf-result {
    margin-top: var(--space-4);
    animation: rfFadeUp 0.4s ease both;
  }

  @keyframes rfFadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rf-card {
    padding: var(--space-4);
    background: var(--color-bg-primary);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--color-border);
    margin-bottom: var(--space-3);
  }

  .rf-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .rf-card-tag {
    display: inline-block;
    padding: 2px var(--space-2);
    background: var(--color-bg-info);
    color: var(--color-text-info);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
  }

  .rf-card-time {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .rf-card-title {
    margin: 0 0 var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  .rf-card-note {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.6;
  }

  .rf-reset-btn {
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border-secondary);
    border-radius: var(--radius-md);
    background: var(--color-bg-primary);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .rf-reset-btn:hover {
    border-color: var(--color-text-info);
    color: var(--color-text-info);
  }

  @media (max-width: 560px) {
    .rf-node {
      min-width: 56px;
      padding: var(--space-2) var(--space-2);
    }
    .rf-node-icon { font-size: 1.1rem; }
    .rf-connector svg { width: 20px; }
  }
</style>

<script>
  (function () {
    var steps = [
      {
        nodeIdx: 0,
        connIdx: -1,
        text: '你点了「刷新 AI 资讯」。浏览器收到这个动作，准备发出一个请求——就像你走进餐厅，开口说了一声"来一份今日推荐"。'
      },
      {
        nodeIdx: 1,
        connIdx: 0,
        text: '请求通过互联网出发了。就像快递上了公路，信号正在飞速传向服务器所在的位置。'
      },
      {
        nodeIdx: 2,
        connIdx: 1,
        text: '服务器收到了请求。它明白你要什么，马上去问数据库：「把最新的 AI 资讯、按重要程度排好，给我。」'
      },
      {
        nodeIdx: 3,
        connIdx: 2,
        text: '数据库翻了一遍记录本——找到了符合条件的资讯，整理好，递给服务器。就像仓库管理员从货架取出货物。'
      },
      {
        nodeIdx: 0,
        connIdx: -1,
        text: '服务器把数据打包，通过互联网送回了你的浏览器。浏览器拿到后，把这堆数据"画"成卡片——完成！'
      }
    ];

    var nodeEls = [
      document.getElementById('rfN0'),
      document.getElementById('rfN1'),
      document.getElementById('rfN2'),
      document.getElementById('rfN3')
    ];
    var connEls = [
      document.getElementById('rfC01'),
      document.getElementById('rfC12'),
      document.getElementById('rfC23')
    ];
    var descEl   = document.getElementById('rfDesc');
    var startBtn = document.getElementById('rfStartBtn');
    var resultEl = document.getElementById('rfResult');
    var resetBtn = document.getElementById('rfResetBtn');

    if (!startBtn || !descEl || !resultEl || !resetBtn) return;

    var timerId = null;

    function clearActive() {
      nodeEls.forEach(function (el) { if (el) el.classList.remove('rf-active'); });
      connEls.forEach(function (el) { if (el) el.classList.remove('rf-active'); });
      if (descEl) descEl.classList.remove('rf-active');
    }

    function runStep(idx) {
      if (idx >= steps.length) {
        resultEl.hidden = false;
        return;
      }
      clearActive();
      var step = steps[idx];
      var node = nodeEls[step.nodeIdx];
      if (node) node.classList.add('rf-active');
      if (step.connIdx >= 0) {
        var conn = connEls[step.connIdx];
        if (conn) conn.classList.add('rf-active');
      }
      if (descEl) {
        descEl.textContent = step.text;
        descEl.classList.add('rf-active');
      }
      timerId = setTimeout(function () { runStep(idx + 1); }, 1800);
    }

    startBtn.addEventListener('click', function () {
      if (timerId) clearTimeout(timerId);
      startBtn.disabled = true;
      resultEl.hidden = true;
      clearActive();
      if (descEl) {
        descEl.textContent = '出发！';
        descEl.classList.remove('rf-active');
      }
      timerId = setTimeout(function () { runStep(0); }, 400);
    });

    resetBtn.addEventListener('click', function () {
      if (timerId) clearTimeout(timerId);
      resultEl.hidden = true;
      clearActive();
      startBtn.disabled = false;
      if (descEl) {
        descEl.textContent = '准备好了，点上面的按钮开始。';
      }
    });
  })();
</script>
