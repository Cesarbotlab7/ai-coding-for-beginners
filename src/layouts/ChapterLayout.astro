---
import { getStageDefinition } from '../lib/curriculum';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  lessonGoal: string;
  stage: number;
  order: number;
  updated: Date;
  verified: Date;
  verifiedVersion: string;
  estimatedReadingMinutes: number;
  prevChapter?: { slug: string; title: string };
  nextChapter?: { slug: string; title: string };
}

const {
  title,
  summary,
  lessonGoal,
  stage,
  order,
  updated,
  verified,
  verifiedVersion,
  estimatedReadingMinutes,
  prevChapter,
  nextChapter,
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('zh-Hans-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const stageDefinition = getStageDefinition(stage);
---
<BaseLayout title={title} description={summary}>
  <header class="site-nav">
    <a href="/" class="back-link">返回课程地图</a>
    <nav class="chapter-nav" aria-label="章节导航">
      {prevChapter && <a href={`/chapter/${prevChapter.slug}`}>上一单元</a>}
      {nextChapter && <a href={`/chapter/${nextChapter.slug}`}>下一单元</a>}
    </nav>
  </header>

  <main class="chapter-main" id="main-content">
    <header class="chapter-header">
      <span class="stage-badge">{stageDefinition?.label ?? '课程'} · 单元 {order}</span>
      <h1>{title}</h1>
      <p class="chapter-summary">{summary}</p>
      <div class="lesson-goal">
        <span>完成后你能做到</span>
        <p>{lessonGoal}</p>
      </div>
      <p class="chapter-meta">
        约 {estimatedReadingMinutes} 分钟 · 内容更新 {dateFormatter.format(updated)}
      </p>
      <p class="chapter-meta">
        核验版本：{verifiedVersion} · 核验日期 {dateFormatter.format(verified)}
      </p>
    </header>

    <article class="chapter-body">
      <slot />
    </article>

    <footer class="chapter-footer">
      {prevChapter && (
        <a href={`/chapter/${prevChapter.slug}`} class="chapter-nav-link">
          <span>上一单元</span>
          <strong>{prevChapter.title}</strong>
        </a>
      )}
      {nextChapter && (
        <a href={`/chapter/${nextChapter.slug}`} class="chapter-nav-link next">
          <span>下一单元</span>
          <strong>{nextChapter.title}</strong>
        </a>
      )}
    </footer>
  </main>
</BaseLayout>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--home-width);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    border-bottom: var(--border-hairline) solid var(--color-border);
  }

  .back-link,
  .chapter-nav a {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .chapter-nav {
    display: flex;
    gap: var(--space-4);
  }

  .chapter-main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-7) var(--space-5);
  }

  .chapter-header {
    margin-bottom: var(--space-7);
  }

  .stage-badge {
    display: inline-block;
    margin-bottom: var(--space-4);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--color-bg-info);
    color: var(--color-text-info);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
  }

  h1 {
    margin-bottom: var(--space-3);
    font-size: var(--text-2xl);
  }

  .chapter-summary {
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    line-height: 1.6;
  }

  .lesson-goal {
    margin: var(--space-5) 0;
    padding: var(--space-4);
    border-left: var(--border-strong) solid var(--color-text-info);
    background: var(--color-bg-info);
  }

  .lesson-goal span {
    color: var(--color-text-info);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
  }

  .lesson-goal p {
    margin: var(--space-1) 0 0;
  }

  .chapter-meta {
    margin-bottom: var(--space-1);
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
  }

  .chapter-footer {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: var(--border-hairline) solid var(--color-border);
  }

  .chapter-nav-link {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .chapter-nav-link:hover {
    background: var(--color-bg-secondary);
  }

  .chapter-nav-link span {
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
  }

  .chapter-nav-link strong {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
  }

  .chapter-nav-link.next {
    text-align: right;
  }

  @media (max-width: 40rem) {
    .site-nav {
      align-items: flex-start;
      gap: var(--space-3);
      padding: var(--space-4);
    }

    .chapter-nav {
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .chapter-main {
      padding: var(--space-5) var(--page-gutter-mobile);
    }

    .chapter-footer {
      flex-direction: column;
    }

    .chapter-nav-link.next {
      text-align: left;
    }
  }
</style>
