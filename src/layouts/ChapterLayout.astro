---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  stage: number;
  order: number;
  updated: Date;
  estimatedReadingMinutes?: number;
  prevChapter?: { slug: string; title: string };
  nextChapter?: { slug: string; title: string };
}

const stageLabels: Record<number, string> = {
  0: '引子',
  1: '阶段一·地图',
  2: '阶段二·玩家',
  3: '阶段三·动手',
};

const {
  title, summary, stage, order, updated,
  estimatedReadingMinutes, prevChapter, nextChapter,
} = Astro.props;

const updatedStr = updated.toLocaleDateString('zh-Hans-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const stageLabel = stageLabels[stage] ?? '未知阶段';
---
<BaseLayout title={title}>
  <header class="site-nav">
    <a href="/" class="back-link">← 返回目录</a>
    <nav class="chapter-nav" aria-label="章节导航">
      {prevChapter && (
        <a href={`/chapter/${prevChapter.slug}`} class="nav-link">← 上一章</a>
      )}
      {nextChapter && (
        <a href={`/chapter/${nextChapter.slug}`} class="nav-link">下一章 →</a>
      )}
    </nav>
  </header>

  <main class="chapter-main">
    <header class="chapter-header">
      <span class="stage-badge">{stageLabel} · 第{order}章</span>
      <h1 class="chapter-title">{title}</h1>
      <p class="chapter-summary">{summary}</p>
      <p class="chapter-meta">
        {updatedStr}
        {estimatedReadingMinutes && ` · 约 ${estimatedReadingMinutes} 分钟`}
      </p>
    </header>

    <div class="chapter-body">
      <slot />
    </div>

    <footer class="chapter-footer">
      {prevChapter && (
        <a href={`/chapter/${prevChapter.slug}`} class="chapter-nav-link prev">
          <span class="nav-label">上一章</span>
          <span class="nav-title">{prevChapter.title}</span>
        </a>
      )}
      {nextChapter && (
        <a href={`/chapter/${nextChapter.slug}`} class="chapter-nav-link next">
          <span class="nav-label">下一章</span>
          <span class="nav-title">{nextChapter.title}</span>
        </a>
      )}
    </footer>
  </main>
</BaseLayout>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 0.5px solid var(--color-border);
    max-width: 880px;
    margin: 0 auto;
  }

  .back-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .back-link:hover {
    color: var(--color-text-primary);
  }

  .chapter-nav {
    display: flex;
    gap: var(--space-4);
  }

  .nav-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .nav-link:hover {
    color: var(--color-text-primary);
  }

  .chapter-main {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5);
  }

  .chapter-header {
    margin-bottom: var(--space-7);
  }

  .stage-badge {
    display: inline-block;
    padding: 2px var(--space-2);
    border-radius: 10px;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    background: var(--color-bg-info);
    color: var(--color-text-info);
    margin-bottom: var(--space-4);
  }

  .chapter-title {
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
    line-height: 1.3;
  }

  .chapter-summary {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
    line-height: 1.6;
  }

  .chapter-meta {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .chapter-footer {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 0.5px solid var(--color-border);
  }

  .chapter-nav-link {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background-color 0.12s;
  }

  .chapter-nav-link:hover {
    background: var(--color-bg-secondary);
  }

  .chapter-nav-link.next {
    text-align: right;
  }

  .nav-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .nav-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
  }

  @media (max-width: 640px) {
    .chapter-main {
      padding: var(--space-5) var(--space-4);
    }

    .chapter-footer {
      flex-direction: column;
    }

    .chapter-nav-link.next {
      text-align: left;
    }
  }
</style>
