---
import { getCollection, render } from 'astro:content';
import ChapterCloser from '../../components/ChapterCloser.astro';
import AgentVsChatLab from '../../components/workbuddy/AgentVsChatLab.astro';
import ArtifactAcceptanceLab from '../../components/workbuddy/ArtifactAcceptanceLab.astro';
import AutomationCapstoneLab from '../../components/workbuddy/AutomationCapstoneLab.astro';
import CapabilityMatcherLab from '../../components/workbuddy/CapabilityMatcherLab.astro';
import FirstTaskLab from '../../components/workbuddy/FirstTaskLab.astro';
import InstallWizardLab from '../../components/workbuddy/InstallWizardLab.astro';
import InterfaceMapLab from '../../components/workbuddy/InterfaceMapLab.astro';
import MemoryReviewLab from '../../components/workbuddy/MemoryReviewLab.astro';
import ModePermissionLab from '../../components/workbuddy/ModePermissionLab.astro';
import PromptBuilderLab from '../../components/workbuddy/PromptBuilderLab.astro';
import WorkspaceSafetyLab from '../../components/workbuddy/WorkspaceSafetyLab.astro';
import ChapterLayout from '../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  const sorted = chapters.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((chapter, index) => ({
    params: { slug: chapter.data.slug },
    props: {
      chapter,
      previous: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { chapter, previous, next } = Astro.props;
const { Content } = await render(chapter);
const previousLink = previous
  ? { slug: previous.data.slug, title: previous.data.title }
  : undefined;
const nextLink = next
  ? { slug: next.data.slug, order: next.data.order, title: next.data.title }
  : undefined;
---
<ChapterLayout
  title={chapter.data.title}
  summary={chapter.data.summary}
  lessonGoal={chapter.data.lesson_goal}
  stage={chapter.data.stage}
  order={chapter.data.order}
  updated={chapter.data.updated}
  verified={chapter.data.verified}
  verifiedVersion={chapter.data.verified_version}
  estimatedReadingMinutes={chapter.data.estimated_reading_minutes}
  prevChapter={previousLink}
  nextChapter={nextLink}
>
  <Content
    components={{
      AgentVsChatLab,
      InstallWizardLab,
      WorkspaceSafetyLab,
      ModePermissionLab,
      InterfaceMapLab,
      FirstTaskLab,
      PromptBuilderLab,
      ArtifactAcceptanceLab,
      MemoryReviewLab,
      CapabilityMatcherLab,
      AutomationCapstoneLab,
    }}
  />

  <section class="lesson-sources">
    <h2>本单元来源</h2>
    <ul>
      {chapter.data.sources.map((source) => (
        <li><a href={source.url} target="_blank" rel="noreferrer">{source.label}</a></li>
      ))}
    </ul>
  </section>

  <ChapterCloser
    slug={chapter.data.slug}
    takeaways={chapter.data.takeaways}
    next={nextLink}
  />
</ChapterLayout>

<style>
  .lesson-sources {
    margin-top: var(--space-7);
    padding: var(--space-4);
    border: var(--border-hairline) solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-secondary);
  }

  .lesson-sources h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-base);
  }

  .lesson-sources ul {
    margin: 0;
    font-size: var(--text-sm);
  }
</style>
